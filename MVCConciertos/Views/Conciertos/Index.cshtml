@model List<MVCConciertos.Models.Evento>

@{
    ViewData["Title"] = "Explorar Eventos";
    var categorias = ViewData["Categorias"] as List<MVCConciertos.Models.CategoriaEvento> ?? new List<MVCConciertos.Models.CategoriaEvento>();
    int categoriaSeleccionada = (int)(ViewData["CategoriaSeleccionada"] ?? 0);
}

<style>
    body {
        background-color: #0f1014;
        color: #e2e4e9;
    }

    /* Diseño Minimalista & Dark */
    .header-section {
        padding: 4rem 1rem 3rem;
        text-align: center;
        border-bottom: 1px solid #1f2228;
        margin-bottom: 3rem;
    }

    .header-section h1 {
        font-weight: 800;
        font-size: 3rem;
        letter-spacing: -1px;
        color: #ffffff;
    }

    .header-section p {
        color: #8c92a4;
        font-size: 1.1rem;
        max-width: 600px;
        margin: 1rem auto 0;
    }

    /* Estilos para el filtro oscuro minimalista */
    .filter-wrapper {
        max-width: 400px;
        margin: 2rem auto 0;
    }

    .filter-select {
        background-color: #16181d;
        color: #e2e4e9;
        border: 1px solid #3b3f4c;
        border-radius: 0.5rem 0 0 0.5rem;
        padding: 0.75rem 1rem;
    }

    .filter-select:focus {
        background-color: #16181d;
        color: #ffffff;
        border-color: #ffffff;
        box-shadow: none;
    }

    .filter-btn {
        background-color: #ffffff;
        color: #000000;
        border: 1px solid #ffffff;
        border-radius: 0 0.5rem 0.5rem 0;
        font-weight: 600;
        padding: 0 1.5rem;
        transition: all 0.3s ease;
    }

    .filter-btn:hover {
        background-color: #0f1014;
        color: #ffffff;
    }

    .event-card {
        background: #16181d;
        border: 1px solid #23262f;
        border-radius: 1rem;
        overflow: hidden;
        transition: all 0.3s ease;
        height: 100%;
    }

    .event-card:hover {
        transform: translateY(-8px);
        border-color: #3b3f4c;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }

    .event-image-wrapper {
        height: 260px;
        background: #0f1014;
        position: relative;
        overflow: hidden;
    }

    .event-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.85;
        transition: opacity 0.5s ease, transform 0.8s ease;
    }

    .event-card:hover .event-image-wrapper img {
        opacity: 1;
        transform: scale(1.05);
    }

    .card-body {
        padding: 2rem;
    }

    .event-title {
        font-weight: 700;
        font-size: 1.4rem;
        color: #ffffff;
        margin-bottom: 0.3rem;
        letter-spacing: -0.5px;
    }

    .event-artist {
        color: #8c92a4;
        font-size: 1rem;
        margin-bottom: 1.5rem;
    }

    .btn-minimal {
        background: #ffffff;
        color: #000000;
        font-weight: 600;
        border-radius: 0.5rem;
        padding: 0.7rem 1.5rem;
        text-decoration: none;
        display: inline-block;
        transition: background 0.3s ease, color 0.3s ease;
        text-align: center;
        width: 100%;
        border: 1px solid #ffffff;
    }

    .btn-minimal:hover {
        background: transparent;
        color: #ffffff;
    }

    .empty-state {
        text-align: center;
        padding: 5rem 1rem;
        color: #8c92a4;
    }
</style>

<div class="container pb-5">
    
    <!-- Minimalist Header -->
    <div class="header-section">
        <h1>Cartelera de Conciertos</h1>
        <p>Descubre a tus artistas favoritos en un formato simple, oscuro y sin distracciones.</p>

        <!-- Filtro Integrado -->
        <div class="filter-wrapper">
            <form method="get" asp-action="Index">
                <div class="input-group">
                    <select name="idCategoria" class="form-select filter-select" onchange="this.form.submit()">
                        <option value="">-- Todas las categorías --</option>
                        @foreach (var cat in categorias)
                        {
                            if (cat.IdCategoria == categoriaSeleccionada)
                            {
                                <option value="@cat.IdCategoria" selected="selected">@cat.Nombre</option>
                            }
                            else
                            {
                                <option value="@cat.IdCategoria">@cat.Nombre</option>
                            }
                        }
                    </select>
                    <button type="submit" class="btn filter-btn">Filtrar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Grid de Eventos -->
    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var evento in Model)
            {
                <div class="col">
                    <div class="card event-card">
                        <div class="event-image-wrapper">
                            @if (!string.IsNullOrEmpty(evento.Imagen))
                            {
                                string bucketUrl = "https://bucket-examen-lastdance.s3.us-east-1.amazonaws.com/";
                                string urlFinal = $"{bucketUrl}{evento.Imagen}";

                                <img src="@urlFinal" alt="@evento.Nombre" loading="lazy" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex justify-content-center align-items-center">
                                    <h1 class="display-1 opacity-25">🎵</h1>
                                </div>
                            }
                        </div>
                        
                        <div class="card-body d-flex flex-column">
                            <h3 class="event-title">@evento.Nombre</h3>
                            <p class="event-artist">@evento.Artista</p>
                            
                            <div class="mt-auto">
                                <a href="#" class="btn-minimal">Obtener Entradas</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <h3 class="mb-2">Sin eventos programados</h3>
            <p>No hemos encontrado conciertos para esta categoría. Vuelve más tarde o cambia el filtro.</p>
        </div>
    }
</div>